{
  "manifest_version": 3,
  "name": "AI Helper Tools Tester",
  "version": "1.0",
  "description": "MVP расширения для тестирования browser tools через JSON-envelope",
  "permissions": ["tabs", "scripting", "activeTab", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.js"]
    }
  ]
}
